# Sao chép file này thành .env rồi điền giá trị thật
GEMINI_API_KEY=
# Model Gemini hỗ trợ audio (đổi theo model bạn có quyền truy cập)
GEMINI_MODEL=gemini-2.5-flash
# Giới hạn dung lượng file upload (MB)
MAX_FILE_MB=200
# Tên hiển thị ở footer biên bản
FOOTER_TEXT=AI Meeting Notes
# Mật khẩu bảo vệ (HTTP Basic). Để TRỐNG khi chạy local; ĐẶT giá trị khi deploy public.
APP_PASSWORD=
